{
  "expo": {
    "name": "ViralShop",
    "slug": "frontend",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000B26"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.diegogc.viralshop",
      "googleServicesFile": "./google-services.json",
      "navigationBar": { "backgroundColor": "#000000" }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-location",
        {
           "locationAlwaysAndWhenInUsePermission": "Permite que ViralShop use tu ubicación para mostrarte los productos y videos que están cerca de ti."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "626d3266-821d-4f7f-ba5e-21aac6872a81"
      }
    }
  }
}
