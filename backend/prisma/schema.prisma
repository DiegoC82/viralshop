generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Mantenemos los roles para el futuro E-commerce
enum UserRole {
  BUYER
  SELLER
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  username    String       @unique
  name        String
  password    String       // <-- ¡Añadimos este campo!
  avatarUrl   String?
  bio         String?
  pushToken   String?      // 👈 ¡Agregamos esto para las notificaciones!
  // 👇 NUEVOS CAMPOS: Identidad Secreta (+18) 👇
  adultUsername  String?
  adultAvatarUrl String?
  adultBio       String?
  adultFollowers AdultFollows[] @relation("adultFollowing")
  adultFollowing AdultFollows[] @relation("adultFollower")
  role        UserRole     @default(BUYER)
  isVerified  Boolean      @default(false) // Perfil verificado
  createdAt   DateTime     @default(now())
  lastActive    DateTime  @default(now())

  // Relaciones Sociales
  interests   Interest[]   @relation("UserInterests")
  videos      Video[]
  likes       Like[]
  comments    Comment[]
  savedVideos SavedVideo[]
  // Relaciones de Mensajería
  chats     Chat[]    @relation("ChatParticipants")
  messages  Message[]
  bids      Bid[]     @relation("UserBids")
  followers Follows[] @relation("following")
  following Follows[] @relation("follower")
  reportsMade Report[] @relation("UserReports")
}

// Para que el usuario elija qué le gusta al iniciar
model Interest {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]   @relation("UserInterests")
}

model Video {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  videoUrl     String 
  muxAssetId   String?      //   👈 NUEVO: Guardaremos el ID físico de Mux aquí   
  description  String?
  viewCount    Int          @default(0)
  createdAt    DateTime     @default(now())
  
  productName  String?
  productPrice Float?
  discountPrice   Float?   // 👈 NUEVO: Precio rebajado (Oferta)
  productLink  String?
  thumbnailTime   Int      @default(1) // 👈 Nuevo: Segundo elegido para la portada

  // 👇 1. NUEVOS CAMPOS DE FILTROS Y MAPA 👇
  category     String?
  subCategory  String?
  latitude     Float?
  longitude    Float? 
  likes        Like[]
  comments     Comment[]
  savedBy      SavedVideo[]

  // 👇 NUEVOS CAMPOS PARA REMATES 👇
  isAuction     Boolean   @default(false)
  is18Plus        Boolean      @default(false) // 👈 NUEVO: Marcador de contenido adulto
  auctionEndsAt DateTime?
  isAuctionClosed Boolean   @default(false) // <-- ¡Añadimos esto!
  bids          Bid[]     @relation("VideoBids")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId]) // Un usuario solo puede dar un like por video
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}

model SavedVideo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId]) // Evita guardar el mismo video dos veces
}

// 👇 NUEVOS MODELOS PARA EL SISTEMA DE MENSAJERÍA 👇

model Chat {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relaciones
  participants User[]    @relation("ChatParticipants")
  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  
  // Relaciones
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
}

// 👇 NUEVO MODELO PARA EL SISTEMA DE REMATES 👇
model Bid {
  id        String   @id @default(cuid())
  amount    Float    // Cantidad de dinero de la oferta
  createdAt DateTime @default(now())
  
  // Quién hizo la oferta
  userId    String
  user      User     @relation("UserBids", fields: [userId], references: [id])
  
  // A qué producto (Remate) se le hizo la oferta
  videoId   String
  video     Video    @relation("VideoBids", fields: [videoId], references: [id])
}

// Y agrega este nuevo modelo al final de tu archivo schema.prisma
model Follows {
  followerId  String
  followingId String

  // 👇 ESTA ES LA LÍNEA MÁGICA QUE TE FALTÓ 👇
  createdAt   DateTime @default(now()) 

  follower    User @relation("follower", fields: [followerId], references: [id])
  following   User @relation("following", fields: [followingId], references: [id])
  
  @@id([followerId, followingId])
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String   // Quién hace la denuncia
  targetId    String   // ID del video o del perfil denunciado
  type        String   // Puede ser "VIDEO" o "PROFILE"
  reason      String   // El motivo profesional que eligió
  status      String   @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt   DateTime @default(now())

  reporter    User     @relation("UserReports", fields: [reporterId], references: [id])
}

// 👇 NUEVA TABLA: Seguidores exclusivos para el lado oscuro
model AdultFollows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User @relation("adultFollower", fields: [followerId], references: [id])
  following   User @relation("adultFollowing", fields: [followingId], references: [id])
  
  @@id([followerId, followingId])
}