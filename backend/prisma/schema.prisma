generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Mantenemos los roles para el futuro E-commerce
enum UserRole {
  BUYER
  SELLER
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  username    String       @unique
  name        String
  password    String       // <-- ¡Añadimos este campo!
  avatarUrl   String?
  bio         String?
  role        UserRole     @default(BUYER)
  isVerified  Boolean      @default(false) // Perfil verificado
  createdAt   DateTime     @default(now())

  // Relaciones Sociales
  interests   Interest[]   @relation("UserInterests")
  videos      Video[]
  likes       Like[]
  comments    Comment[]
  savedVideos SavedVideo[]
}

// Para que el usuario elija qué le gusta al iniciar
model Interest {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]   @relation("UserInterests")
}

model Video {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  videoUrl     String       // URL del video (después conectaremos Mux)
  description  String?
  viewCount    Int          @default(0)
  createdAt    DateTime     @default(now())
  
  // 👇 NUEVOS CAMPOS E-COMMERCE 👇
  productName   String?
  productPrice  Float?
  productLink   String?
  
  // Relaciones Sociales
  likes        Like[]
  comments     Comment[]
  savedBy      SavedVideo[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId]) // Un usuario solo puede dar un like por video
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}

model SavedVideo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId]) // Evita guardar el mismo video dos veces
}